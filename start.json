{
  "run": [
    {
      "method": "shell.run",
      "params": {
        "venv": "env",
        "message": [
          "python app.py"
        ],
        "on": [
          {
            "match": "(http://127.0.0.1:[0-9]+)",
            "return": "{{$match[1]}}"
          }
        ]
      }
    }
  ]
}